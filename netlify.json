{
  "build": {
    "command": "npm run build",
    "publish": "build"
  },
  "redirects": [
    {
      "from": "/*",
      "to": "/index.html",
      "status": 200
    }
  ],
  "headers": [
    {
      "for": "/*",
      "values": {
        "X-Frame-Options": "DENY",
        "X-XSS-Protection": "1; mode=block",
        "X-Content-Type-Options": "nosniff"
      }
    }
  ],
  "env": {
    "REACT_APP_OPENAI_MODEL": "gpt-4o-mini"
  }
}